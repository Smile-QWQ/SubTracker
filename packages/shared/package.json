{
  "name": "@subtracker/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./i18n": {
      "types": "./src/i18n.ts",
      "import": "./dist/i18n.js",
      "require": "./dist/i18n.cjs",
      "default": "./dist/i18n.js"
    },
    "./locale-core": {
      "types": "./src/locale-core.ts",
      "import": "./dist/locale-core.js",
      "require": "./dist/locale-core.cjs",
      "default": "./dist/locale-core.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/i18n.ts src/locale-core.ts --format esm,cjs --dts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^3.1.1"
  }
}
